using System;
using System.Text;

namespace EcoLRTB
{
    public enum EcoUnit { Px = 0, Pt, Mm, In, Dxa, Emu, Rem }

    public enum EcoPreset { Compact, Standard, Wide, Document, Web }

    public enum EcoTarget { Generic, Txt, Md, Html, Docx, Pdf, Xml, Php }

    public readonly struct EcoRect
    {
        public readonly int L;
        public readonly int R;
        public readonly int T;
        public readonly int B;

        public EcoRect(int l, int r, int t, int b) { L=l; R=r; T=t; B=b; }
        public EcoRect(int all) { L=R=T=B=all; }

        public static EcoRect Compact  => new( 48,  48,  48,  48);
        public static EcoRect Standard => new( 72,  72,  96,  96);
        public static EcoRect Wide     => new( 96,  96, 144, 144);
        public static EcoRect Document => new(138, 138, 138, 138);
        public static EcoRect Web      => new(  0,   0,   0,   0);

        public static EcoRect FromPreset(EcoPreset p) => p switch {
            EcoPreset.Compact  => Compact,
            EcoPreset.Wide     => Wide,
            EcoPreset.Document => Document,
            EcoPreset.Web      => Web,
            _                  => Standard,
        };

        public static EcoRect operator +(EcoRect a, EcoRect b)
            => new(a.L+b.L, a.R+b.R, a.T+b.T, a.B+b.B);

        public static EcoRect operator *(EcoRect a, double factor)
            => new((int)Math.Round(a.L*factor), (int)Math.Round(a.R*factor),
                   (int)Math.Round(a.T*factor), (int)Math.Round(a.B*factor));

        public EcoRect Clamp(int min, int max)
            => new(Math.Clamp(L,min,max), Math.Clamp(R,min,max),
                   Math.Clamp(T,min,max), Math.Clamp(B,min,max));

        public EcoRect ToUnit(EcoUnit from, EcoUnit to)
            => new(EcoConverter.Convert(L,from,to),
                   EcoConverter.Convert(R,from,to),
                   EcoConverter.Convert(T,from,to),
                   EcoConverter.Convert(B,from,to));

        public string ToCss()
            => $"{T}px {R}px {B}px {L}px";

        public string ToCssBlock(string prop = "margin")
            => $"{prop}-top:{T}px;{prop}-right:{R}px;{prop}-bottom:{B}px;{prop}-left:{L}px;";

        public string ToOoxmlPgMar() {
            var d = ToUnit(EcoUnit.Px, EcoUnit.Dxa);
            return $"<w:pgMar w:left=\"{d.L}\" w:right=\"{d.R}\" " +
                   $"w:top=\"{d.T}\" w:bottom=\"{d.B}\" " +
                   $"w:header=\"720\" w:footer=\"720\"/>";
        }

        public string ToXml(string tag = "eco:lrtb")
            => $"<{tag} L=\"{L}\" R=\"{R}\" T=\"{T}\" B=\"{B}\"/>";

        public string ToPhp()
            => $"['L'=>{L},'R'=>{R},'T'=>{T},'B'=>{B}]";

        public string ToPython()
            => $"{{'L':{L},'R':{R},'T':{T},'B':{B}}}";

        public string ToJson()
            => $"{{\"L\":{L},\"R\":{R},\"T\":{T},\"B\":{B}}}";

        public override string ToString() => $"EcoRect(L={L},R={R},T={T},B={B})";

        public override bool Equals(object? obj) =>
            obj is EcoRect r && r.L==L && r.R==R && r.T==T && r.B==B;

        public override int GetHashCode() => HashCode.Combine(L,R,T,B);
    }

    public static class EcoConverter
    {
        private static readonly double[,] Ratio = {
            {   1.0,      0.75,     0.26458,   0.010417,    15.0,     9525.0,    0.0625    },
            {   1.33333,  1.0,      0.35278,   0.013889,    20.0,     12700.0,   0.08333   },
            {   3.77953,  2.83465,  1.0,       0.039370,    56.6929,  360000.0,  0.23622   },
            {  96.0,     72.0,     25.4,       1.0,       1440.0,    914400.0,   6.0       },
            {   0.06667,  0.05,     0.01764,   0.000694,    1.0,      635.0,     0.004167  },
            {   0.000105, 0.0000787,0.000002778,0.0000011,  0.001575, 1.0,       0.00000655},
            {  16.0,     12.0,      4.23333,   0.16667,   240.0,    152400.0,   1.0       },
        };

        public static int Convert(int value, EcoUnit from, EcoUnit to)
        {
            if (from == to) return value;
            return (int)Math.Round(value * Ratio[(int)from, (int)to]);
        }
    }

    public class EcoContext
    {
        public EcoRect   Margin     { get; set; } = EcoRect.Standard;
        public EcoRect   Padding    { get; set; } = new(0);
        public EcoRect   Border     { get; set; } = new(0);
        public EcoTarget Target     { get; set; } = EcoTarget.Generic;
        public EcoUnit   Unit       { get; set; } = EcoUnit.Px;
        public int       PageWidth  { get; set; } = 816;
        public int       PageHeight { get; set; } = 1056;
        public bool      Symmetric  { get; set; } = false;

        public static EcoContext For(EcoTarget target) => new() {
            Target = target,
            Margin = target switch {
                EcoTarget.Docx or EcoTarget.Pdf => EcoRect.Document,
                EcoTarget.Html or EcoTarget.Php => EcoRect.Web,
                _ => EcoRect.Standard,
            }
        };

        public string ToCssRoot() {
            var sb = new StringBuilder();
            sb.AppendLine(":root {");
            sb.AppendLine($"  --eco-margin-left:   {Margin.L}px;");
            sb.AppendLine($"  --eco-margin-right:  {Margin.R}px;");
            sb.AppendLine($"  --eco-margin-top:    {Margin.T}px;");
            sb.AppendLine($"  --eco-margin-bottom: {Margin.B}px;");
            sb.AppendLine($"  --eco-pad-left:      {Padding.L}px;");
            sb.AppendLine($"  --eco-pad-right:     {Padding.R}px;");
            sb.AppendLine($"  --eco-pad-top:       {Padding.T}px;");
            sb.AppendLine($"  --eco-pad-bottom:    {Padding.B}px;");
            sb.AppendLine("}");
            return sb.ToString();
        }
    }
}
