          try {
            report = JSON.parse(
              fs.readFileSync('.github/reports/latest.json','utf8')
            );
          } catch(e) {
            console.log('No report found, skipping fixes');
            process.exit(0);
          }

          const fixes_applied = [];

          // Fix 1: Create missing required directories
          const REQUIRED_DIRS = [
            'core','nitro','polyfill','apache','maven','xml','ftp',
            '.github/reports',
          ];
          for (const dir of REQUIRED_DIRS) {
            if (!fs.existsSync(dir)) {
              fs.mkdirSync(dir, { recursive: true });
              // Add a .gitkeep so the empty dir is tracked
              fs.writeFileSync(path.join(dir, '.gitkeep'), '');
              fixes_applied.push(`Created missing directory: ${dir}/`);
            }
          }

          // Fix 2: Move misplaced files
          for (const issue of report.errors) {
            if (issue.move) {
              const { from, to } = issue.move;
              if (fs.existsSync(from)) {
                fs.mkdirSync(path.dirname(to), { recursive: true });
                fs.copyFileSync(from, to);
                fs.unlinkSync(from);
                fixes_applied.push(`Moved ${from} to ${to}`);
              }
            }
          }

          // Fix 3: Rename files with spaces
          for (const issue of report.warnings) {
            if (issue.rename) {
              const { from, to } = issue.rename;
              if (fs.existsSync(from)) {
                fs.mkdirSync(path.dirname(to
